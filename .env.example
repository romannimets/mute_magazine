# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ─── Cloudinary ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=il-tuo-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=cloudinary-preset-name
# ─── URL base (OBBLIGATORIO in produzione) ────────────────────────────────────
# In sviluppo locale va bene anche senza (default a localhost:3000)
# Su Vercel: impostare con l'URL finale del sito (senza trailing slash)
NEXT_PUBLIC_BASE_URL=https://muterivista.it
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Stringa segreta usata come session token (cambiarla prima del deploy)
ADMIN_SECRET=cambia-questa-stringa-con-qualcosa-di-lungo-e-random
# se true protegge anche pagine publice con admin login
MAINTENANCE_MODE = true/false

GA4_PROPERTY_ID=property id di googleAnalytics (NON quello che inizia con G-, che è measurement ID)
GOOGLE_SERVICE_ACCOUNT_JSON={
Jsonozzo del service account preso da google cloud (tutto su una riga con \n)
}
